    <event eventtype="4" ename="obj_player">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>stunned = 200;

if (place_meeting(x, y, obj_player) &amp;&amp; state == 83 &amp;&amp; obj_player.state == 0) {
	instance_create(x + (obj_player.xscale * 40), y, obj_punchdust);
	other.state = 7;
	other.movespeed = 0;
	state = 86;
} else {
	with (obj_player) {
		if (y &lt; other.y &amp;&amp; attacking == 0 &amp;&amp; (state == 37 || state == 11)) {
			if (other.state != 85 &amp;&amp; key_jump2 &amp;&amp; vsp &gt; 0) {
				audio_play_sound(sfx_boing, 1, false);
				sprite_index = spr_player_stompprep;
				image_index = 0;
				stompAnim = 1;
				vsp = -14;
				state = 37;
				instance_create(x, y, obj_bangeffect);
				other.state = 85;
				other.stunned = 200;
				other.image_index = 0;
			}
		}
		
		if (y &lt; other.y &amp;&amp; sprite_index == spr_player_facestomp) {
			if (other.state != 85 &amp;&amp; vsp &gt; 0) {
				image_index = 0;
				facestompAnim = 1;
				vsp = -7;
				instance_create(x, y, obj_bangeffect);
				other.state = 85;
				other.stunned = 200;
				other.image_index = 0;
			}
		}
		
		if (other.flying == 0) {
			if (!place_meeting(x, y + 1, obj_collisionparent) &amp;&amp; (state == 49 || state == 69 || state == 16)) {
				hsp = -xscale * 4;
				vsp = -4;
				
				if (x != other.x)
					other.image_xscale = -sign(other.x - x);
				
				other.state = 78;
				instance_create(x, y, obj_bangeffect);
				image_index = 0;
				state = 36;
				other.stunned = 200;
			}
		}
		
		if ((state == 49 || state == 69 || state == 16 || state == 53 || state == 22) &amp;&amp; place_meeting(x, y + 1, obj_collisionparent) &amp;&amp; other.flying == 0) {
			if (x != other.x)
				other.image_xscale = -sign(other.x - x);
			
			other.hsp = sign(other.x - x) * 5;
			image_index = 0;
			instance_create(x, y, obj_bangeffect);
			machpunchAnim = 1;
			
			if (state != 69 &amp;&amp; state != 16)
				other.vsp = -10;
			
			if (state == 69 || state == 16)
				other.vsp = -18;
			
			other.state = 82;
			other.stunned = 200;
		}
	}
}
</string>
          </argument>
        </arguments>
      </action>
