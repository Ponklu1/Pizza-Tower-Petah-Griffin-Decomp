		break;
	
	case 85:
	
		scr_enemy_stomped();
		break;
	
	case 86:
	
		scr_enemy_grabbed();
		break;
}

if (state != 82 &amp;&amp; state != 77 &amp;&amp; state != 86 &amp;&amp; state != 76 &amp;&amp; state != 78)
	flying = 0;
else
	flying = 1;

if (cigar == 1 &amp;&amp; cigarcreate == 0 &amp;&amp; (state == 73 || state == 79 || state == 75 || state == 81)) {
